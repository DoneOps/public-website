---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { kebabCase } from 'change-case';

const blogPosts = await getCollection('blog');
const caseStudies = await getCollection('casestudies');

const allPosts = [...blogPosts, ...caseStudies];

const tagCounts: Record<string, number> = {};
allPosts.forEach((post) => {
  if (post.data.tags) {
    post.data.tags.forEach((tag: string) => {
      tagCounts[tag] = (tagCounts[tag] || 0) + 1;
    });
  }
});

const tags = Object.entries(tagCounts).sort((a, b) => a[0].localeCompare(b[0]));
---

<BaseLayout title="Tags | DoneOps">
  <Header slot="header" isSubPage={true} />

  <section class="py-20">
    <div class="container mx-auto px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl font-bold text-slate-900 dark:text-slate-100 mb-12">Tags</h1>
        <ul class="flex flex-wrap justify-center gap-3">
          {tags.map(([tag, count]) => (
            <li>
              <a
                href={`/tags/${kebabCase(tag)}/`}
                class="inline-block px-4 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-full text-sm font-medium hover:bg-primary-100 dark:hover:bg-primary-900 hover:text-primary-700 dark:hover:text-primary-300 transition-colors no-underline"
              >
                {tag} ({count})
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
