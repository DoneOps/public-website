---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Page Not Found | DoneOps" description="The page you're looking for doesn't exist.">
  <Header slot="header" isSubPage={true} />

  <section class="py-20 lg:py-40">
    <div class="container mx-auto text-center px-8">
      <h1 class="text-6xl font-bold text-slate-900 dark:text-slate-100 mb-4">404</h1>
      <p class="text-xl text-slate-600 dark:text-slate-400 mb-8">
        You just hit a route that doesn't exist... the sadness.
      </p>
      <a href="/" class="btn btn-primary text-white px-8 py-3 rounded-lg no-underline hover:no-underline hover:text-white">
        Go Home
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
